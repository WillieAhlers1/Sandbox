            "project": "prj-0n-dta-pt-ai-sandbox",
            "query": [
              {
                "allow_large_results": false,
                "create_disposition": "CREATE_IF_NEEDED",
                "default_dataset": [],
                "destination_encryption_configuration": [],
                "destination_table": [],
                "flatten_results": false,
                "maximum_billing_tier": 0,
                "maximum_bytes_billed": "",
                "parameter_mode": "",
                "priority": "INTERACTIVE",
                "query": "-- BigQuery: Churn prediction features\n-- This table is CREATED by Terraform when provisioning\n\nCREATE OR REPLACE TABLE `dsci_churn_prediction_new_main`.churn_prediction_features AS\n\nWITH base AS (\n  SELECT *\n  FROM `dsci_churn_prediction_new_main`.raw_events\n  WHERE DATE(event_timestamp) = '2026-03-04'\n),\n\naggregated AS (\n  SELECT\n    user_id,\n    COUNT(*) AS total_events,\n    COUNTIF(event_type = 'login') AS login_events,\n    COUNTIF(event_type = 'purchase') AS purchase_events,\n    COUNT(DISTINCT session_id) AS session_count,\n    MAX(event_timestamp) AS last_event_time\n  FROM base\n  GROUP BY user_id\n),\n\nlabeled AS (\n  SELECT\n    *,\n    CASE\n      WHEN total_events \u003c 3 AND login_events \u003c 2 THEN 1\n      ELSE 0\n    END AS is_churned\n  FROM aggregated\n)\n\nSELECT *\nFROM labeled\n",
                "schema_update_options": null,
                "script_options": [],
                "use_legacy_sql": false,
                "use_query_cache": true,
                "user_defined_function_resources": [],
                "write_disposition": "WRITE_EMPTY"
              }
            ],
