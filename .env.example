# GCP ML Framework — environment variable overrides
# Copy to .env and fill in values. Never commit .env.

# Core identity (can also be set in framework.yaml)
GML_TEAM=dsci
GML_PROJECT=my-project

# GCP project IDs per environment
GML_GCP__DEV_PROJECT_ID=my-gcp-project-dev
GML_GCP__STAGING_PROJECT_ID=my-gcp-project-staging
GML_GCP__PROD_PROJECT_ID=my-gcp-project-prod
GML_GCP__REGION=us-central1

# Workload Identity / service account (leave blank to use application default credentials)
GML_GCP__SERVICE_ACCOUNT_EMAIL=

# Secret Manager
GML_SECRETS__SECRET_PREFIX=   # leave blank to use namespace token

# Set by CI/CD to force a specific git-state env resolution
# Values: dev | staging | prod
GML_ENV_OVERRIDE=
